# 向量化模型配置
EMBEDDING_MODEL=local
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_LAZY_LOAD=true  # 是否启用懒加载（推荐开启，可减少启动内存占用）

# GitHub 配置
GITHUB_TOKEN=ghp_xxx   # 可选，提高 API 限流

# 数据存储路径
DATA_DIR=<DATA_DIR>/micro_app_mcp

# 可选：当 DATA_DIR 不可写时的回退目录
FALLBACK_DATA_DIR=/tmp/micro_app_mcp

# 智能缓存配置（可选）
CACHE_DURATION_HOURS=24
SEARCH_TIMEOUT_SECONDS=30

# 更新任务元数据保留策略（可选）
UPDATE_JOB_RETENTION_HOURS=168
UPDATE_JOB_MAX_RECORDS=200

# /micro 更新意图识别规则（可选，逗号分隔）
UPDATE_INTENT_ACTION_KEYWORDS=更新,同步,重建,刷新,update,refresh,rebuild,sync
UPDATE_INTENT_TARGET_KEYWORDS=知识库,向量库,索引,vector,embedding,index,db,database
UPDATE_INTENT_SEARCH_ONLY_PATTERNS=更新日志,changelog,release note,release notes,版本更新,最新更新
