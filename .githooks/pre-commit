#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "pre-commit: running checks..."

# 只做代码检查，不格式化
if command -v uv >/dev/null 2>&1; then
  uv run ruff check src/ tests/ --fix
else
  ruff check src/ tests/ --fix
fi

git add -u src/ tests/

echo "pre-commit: all checks passed"